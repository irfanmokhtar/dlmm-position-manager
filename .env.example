# Copy to .env.local and fill in. .env* is gitignored — never commit real values.

# Premium Solana RPC (Helius / QuickNode / Triton). Public RPC will rate-limit the DLMM SDK hard.
RPC_URL=https://your-premium-rpc.example.com

# Wallets selectable from the in-app dropdown. JSON array of { secret, label? }.
# First entry is the default. label is optional (UI falls back to a truncated pubkey).
# Each secret accepts either:
#  - base58 string (Phantom "export private key"), or
#  - JSON byte array, e.g. [12,34,...] (solana-keygen / id.json contents)
# NOTE: inner JSON-array secrets must be quoted as a string inside the WALLETS JSON.
WALLETS=[{"label":"Main","secret":""},{"label":"Alt","secret":""}]

# Legacy single-wallet fallback. Used only if WALLETS is unset. Same formats as above.
# WALLET_SECRET=

# DLMM pool to manage. Defaults to the SOL/USDC pool if unset.
POOL_ADDRESS=
